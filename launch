#!/bin/bash
# Praxis launcher. Declarative tunables up top, general machinery below.
# Subcommands:
#   ./launch [args...]          train locally (venv auto-created)
#   ./launch test [pytest...]   route args to pytest inside the venv
#   ./launch compose [args...]  re-run this script inside Docker compose
#   ./launch stop               tear down a running compose instance
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Configuration ────────────────────────────────────────────────────────────
# Everything tunable or data-like lives here, so adding a mounted flag or
# changing a compose file never means editing control flow below.

# Docker compose files by architecture (x86_64 = GPU, ARM = CPU-only).
COMPOSE_FILE_DEFAULT="compose.yml"
COMPOSE_FILE_ARM="compose.ARM.yml"

# Files whose content gates the compose auto-rebuild: changing any of these
# re-runs `docker compose build` (stamped per compose file, so an arch switch
# rebuilds correctly). Source edits and pyproject changes deliberately do NOT
# rebuild - praxis/ is bind-mounted live and the venv installs at runtime.
BUILD_INPUTS=(Dockerfile compose.yml)

# CLI flags whose values are host paths: each is resolved to an absolute path
# and bind-mounted read-only into the container at the same location. Flags
# here may take multiple values (nargs-style) and comma-separated lists.
MOUNT_FLAGS=(--data-path)

# CLI flags whose values publish container ports, as "<flag>:<env-var>" pairs.
# The env var is read by the compose file's ${VAR} substitution; unset means
# compose falls back to its own defaults (2100 / 29500).
PORT_FLAGS=(--port:PRAXIS_PORT --master-port:PRAXIS_MASTER_PORT)

# In-container identity: HOME for the re-exec'd host user, and the venv dir
# (a named volume in Docker, a plain directory on the host).
CONTAINER_HOME=/home/dev
VENV_DIR=.venv

# ── Compose helpers ──────────────────────────────────────────────────────────

compose_file() {
    case "$(uname -m)" in
        aarch64|arm64) echo "$SCRIPT_DIR/$COMPOSE_FILE_ARM" ;;
        *)             echo "$SCRIPT_DIR/$COMPOSE_FILE_DEFAULT" ;;
    esac
}

# Rebuild the image only when the Docker build inputs (BUILD_INPUTS + the active
# compose file) change, stamped per compose file. Unchanged inputs fall through
# to the cached image. Set PRAXIS_NO_AUTOBUILD=1 to skip entirely.
autobuild_image() {
    local cf="$1"
    [ -n "${PRAXIS_NO_AUTOBUILD:-}" ] && return
    command -v docker &>/dev/null || return
    local stamp="$SCRIPT_DIR/.docker-build.$(basename "$cf").stamp"
    local inputs=("${BUILD_INPUTS[@]/#/$SCRIPT_DIR/}" "$cf")
    local hash
    hash=$(cat "${inputs[@]}" 2>/dev/null | sha256sum | cut -d' ' -f1)
    if [ "$hash" != "$(cat "$stamp" 2>/dev/null)" ]; then
        echo "[DOCKER] Build inputs changed since last build - rebuilding image..."
        if docker compose -f "$cf" build; then
            echo "$hash" > "$stamp"
        else
            echo "[DOCKER] Image build failed; continuing with the existing image." >&2
        fi
    else
        echo "[DOCKER] Image up to date (Docker build inputs unchanged)."
    fi
}

# Walk the args once, driven by launch.conf:
#   MOUNT_FLAGS - resolve each value (nargs + comma lists) to an absolute host
#     path, bind-mount it read-only at the same path, and pass the resolved
#     path through (mirrors the comma-or-list handling on the Python side).
#   PORT_FLAGS - export the value under the paired env var so the compose
#     file's ${VAR} substitution publishes the matching host port.
# Results land in RESOLVED_ARGS / EXTRA_VOLUMES.
parse_compose_args() {
    RESOLVED_ARGS=()
    EXTRA_VOLUMES=""
    local mounting=false expect_env=""
    local arg flag env_var
    for arg in "$@"; do
        if [ -n "$expect_env" ]; then
            export "$expect_env"="$arg"
            expect_env=""
            RESOLVED_ARGS+=("$arg")
            continue
        fi
        # A new flag ends any in-progress mount-value capture.
        if $mounting && [[ "$arg" == -* ]]; then
            mounting=false
        fi
        if $mounting; then
            local _p abs_path
            IFS=',' read -ra _paths <<< "$arg"
            for _p in "${_paths[@]}"; do
                [ -z "$_p" ] && continue
                abs_path="$(cd "$SCRIPT_DIR" && realpath -m "$_p" 2>/dev/null || echo "$_p")"
                EXTRA_VOLUMES="$EXTRA_VOLUMES -v $abs_path:$abs_path:ro"
                RESOLVED_ARGS+=("$abs_path")
            done
            continue
        fi
        for flag in "${MOUNT_FLAGS[@]}"; do
            if [ "$arg" = "$flag" ]; then mounting=true; break; fi
        done
        for pair in "${PORT_FLAGS[@]}"; do
            flag="${pair%%:*}"; env_var="${pair#*:}"
            if [ "$arg" = "$flag" ]; then expect_env="$env_var"; break; fi
        done
        RESOLVED_ARGS+=("$arg")
    done
}

cmd_stop() {
    echo "[STOP] Stopping Praxis..."
    local cf
    cf=$(compose_file)
    if command -v docker &>/dev/null && [ -f "$cf" ]; then
        docker compose -f "$cf" down --remove-orphans
    fi
    echo "[STOP] Done."
}

cmd_compose() {
    echo "[DOCKER] Starting Praxis in Docker Compose environment..."
    local cf
    cf=$(compose_file)
    case "$cf" in
        *"$COMPOSE_FILE_ARM") echo "[DOCKER] Detected ARM64 architecture - using CPU-only configuration" ;;
        *)                    echo "[DOCKER] Detected x86_64 architecture - using GPU configuration" ;;
    esac

    autobuild_image "$cf"
    parse_compose_args "$@"

    # Pass the host user's ids into the container (compose.yml forwards them as
    # HOST_UID/HOST_GID); the in-container path re-execs as that user so files
    # written into the bind-mounted repo are host-owned, not root.
    export HOST_UID="$(id -u)" HOST_GID="$(id -g)"

    docker compose -f "$cf" run --rm --remove-orphans --service-ports $EXTRA_VOLUMES agent ./launch "${RESOLVED_ARGS[@]}"
}

# ── In-container user setup ──────────────────────────────────────────────────

# Re-exec as the host user so anything written into the bind-mounted repo is
# owned by the host user, not root (the recurring permission headache). The
# host launch passed its ids via HOST_UID/HOST_GID; we chown the named volumes
# (venv, cache under HOME) to match once, then drop privileges with setpriv
# (util-linux, in the base image). The re-exec lands here again as a non-root
# uid and falls straight through.
container_setup() {
    [ -f /.dockerenv ] || [ -n "${CONTAINER:-}" ] || return
    echo "[DOCKER] Running inside container..."

    if [ "$(id -u)" = "0" ] && [ -n "${HOST_UID:-}" ] && [ "${HOST_UID}" != "0" ]; then
        local host_gid="${HOST_GID:-$HOST_UID}"
        export HOME="$CONTAINER_HOME"
        mkdir -p "$HOME" "$SCRIPT_DIR/$VENV_DIR"
        local d
        for d in "$HOME" "$SCRIPT_DIR/$VENV_DIR"; do
            if [ "$(stat -c %u "$d" 2>/dev/null || echo 0)" != "${HOST_UID}" ]; then
                chown -R "${HOST_UID}:${host_gid}" "$d" 2>/dev/null || true
            fi
        done
        # One-time migration: earlier root runs may have left root-owned files
        # in the bind-mounted repo (build/, research/, *.egg-info, __pycache__)
        # that the host user now cannot write. Chown just those non-host-owned
        # files; the sentinel gates the full-tree walk to once per uid (-xdev
        # stays on the bind mount, skipping the volumes handled above).
        local migr="$SCRIPT_DIR/.host-uid-migrated"
        if [ "$(cat "$migr" 2>/dev/null)" != "${HOST_UID}" ]; then
            echo "[DOCKER] Migrating root-owned files to host user (one-time)..."
            find "$SCRIPT_DIR" -xdev -not -user "${HOST_UID}" \
                -exec chown "${HOST_UID}:${host_gid}" {} + 2>/dev/null || true
            echo "${HOST_UID}" > "$migr" 2>/dev/null || true
        fi
        echo "[DOCKER] Running as host user ${HOST_UID}:${host_gid}"
        exec setpriv --reuid="${HOST_UID}" --regid="${host_gid}" --clear-groups \
            "$SCRIPT_DIR/launch" "$@"
    fi

    mkdir -p "$SCRIPT_DIR/$VENV_DIR"
}

# ── Virtual environment ──────────────────────────────────────────────────────

ensure_venv() {
    if [ ! -f "$SCRIPT_DIR/$VENV_DIR/bin/activate" ]; then
        echo "Creating virtual environment..."
        python3 -m venv "$SCRIPT_DIR/$VENV_DIR"
    fi
    echo "[SYSTEM] Activated virtual environment."
    . "$SCRIPT_DIR/$VENV_DIR/bin/activate"
}

ensure_install() {
    [ -f "$SCRIPT_DIR/pyproject.toml" ] || return
    # Require praxis to resolve to THIS repo's source, not merely be importable:
    # a stale non-editable copy in site-packages imports fine but shadows source
    # edits, silently running tests/training against old code. (NB: .venv lives
    # under SCRIPT_DIR, so match the source package dir exactly, not a prefix.)
    if python -c "import praxis,os,sys; sys.exit(0 if os.path.realpath(os.path.dirname(praxis.__file__))==os.path.realpath('$SCRIPT_DIR/praxis') else 1)" 2>/dev/null; then
        echo "[ENV] Praxis is installed (editable)."
    else
        echo "[ENV] Installing Praxis in development mode..."
        pip install -e "$SCRIPT_DIR"
        echo "[ENV] Praxis installation complete"
    fi
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

case "$1" in
    stop)
        cmd_stop
        exit 0
        ;;
    compose)
        shift
        cmd_compose "$@"
        exit $?
        ;;
esac

container_setup "$@"
ensure_venv
ensure_install

if [ "$1" = "test" ]; then
    shift
    pytest "$@"
    EXIT_CODE=$?
else
    python "$SCRIPT_DIR/main.py" "$@"
    EXIT_CODE=$?
fi

deactivate
exit $EXIT_CODE
