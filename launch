#!/bin/bash
# Praxis Launch Script - Simple wrapper for virtual environment management

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if first argument is 'stop' to tear down a running instance
if [ "$1" = "stop" ]; then
    echo "[STOP] Stopping Praxis..."

    ARCH=$(uname -m)
    if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
        COMPOSE_FILE="$SCRIPT_DIR/compose.ARM.yml"
    else
        COMPOSE_FILE="$SCRIPT_DIR/compose.yml"
    fi

    if command -v docker &>/dev/null && [ -f "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" down --remove-orphans
    fi

    echo "[STOP] Done."
    exit 0
fi

# Check if first argument is 'compose' for Docker Compose execution
# We short-circuit, if using Docker, to re-run the script within our container
if [ "$1" = "compose" ]; then
    shift  # Remove 'compose' from arguments

    echo "[DOCKER] Starting Praxis in Docker Compose environment..."

    ARCH=$(uname -m)
    if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
        echo "[DOCKER] Detected ARM64 architecture - using CPU-only configuration"
        COMPOSE_FILE="$SCRIPT_DIR/compose.ARM.yml"
    else
        echo "[DOCKER] Detected x86_64 architecture - using GPU configuration"
        COMPOSE_FILE="$SCRIPT_DIR/compose.yml"
    fi

    # Rebuild the image only when the Docker build inputs change (the Dockerfile
    # or a compose file) - NOT on praxis/ source edits (bind-mounted live) or
    # pyproject changes (installed into the venv volume at runtime). We stamp a
    # hash of those inputs, keyed per compose file so an arch switch rebuilds
    # correctly, and gate an explicit `compose build` on it. Unchanged inputs
    # skip the build and fall through to the cached image; even a triggered
    # rebuild is cheap when Docker's layer cache has nothing material to redo.
    # Set PRAXIS_NO_AUTOBUILD=1 to skip this check entirely.
    if [ -z "${PRAXIS_NO_AUTOBUILD:-}" ] && command -v docker &>/dev/null; then
        STAMP_FILE="$SCRIPT_DIR/.docker-build.$(basename "$COMPOSE_FILE").stamp"
        BUILD_HASH=$(cat "$SCRIPT_DIR/Dockerfile" "$SCRIPT_DIR/compose.yml" "$COMPOSE_FILE" 2>/dev/null | sha256sum | cut -d' ' -f1)
        if [ "$BUILD_HASH" != "$(cat "$STAMP_FILE" 2>/dev/null)" ]; then
            echo "[DOCKER] Build inputs changed since last build - rebuilding image..."
            if docker compose -f "$COMPOSE_FILE" build; then
                echo "$BUILD_HASH" > "$STAMP_FILE"
            else
                echo "[DOCKER] Image build failed; continuing with the existing image." >&2
            fi
        else
            echo "[DOCKER] Image up to date (Docker build inputs unchanged)."
        fi
    fi

    # Parse args for special handling:
    #  --data-path (nargs="+"): resolve to absolute host paths and bind-mount
    #    them into the container at the same path.
    #  --port / --master-port: capture so we can publish the matching host
    #    ports (the compose file reads PRAXIS_PORT / PRAXIS_MASTER_PORT).
    EXTRA_VOLUMES=""
    PRAXIS_PORT_OVERRIDE=""
    PRAXIS_MASTER_PORT_OVERRIDE=""
    RESOLVED_ARGS=()
    CONSUMING_DATA_PATHS=false
    EXPECT_PORT=false
    EXPECT_MASTER_PORT=false
    for arg in "$@"; do
        if $EXPECT_PORT; then
            PRAXIS_PORT_OVERRIDE="$arg"
            EXPECT_PORT=false
            RESOLVED_ARGS+=("$arg")
            continue
        fi
        if $EXPECT_MASTER_PORT; then
            PRAXIS_MASTER_PORT_OVERRIDE="$arg"
            EXPECT_MASTER_PORT=false
            RESOLVED_ARGS+=("$arg")
            continue
        fi
        # A new flag ends any in-progress --data-path value capture.
        if $CONSUMING_DATA_PATHS && [[ "$arg" == -* ]]; then
            CONSUMING_DATA_PATHS=false
        fi
        if $CONSUMING_DATA_PATHS; then
            # A single value may itself be comma-separated (mirrors the
            # comma-or-list handling on the Python side); mount each path.
            IFS=',' read -ra _paths <<< "$arg"
            for _p in "${_paths[@]}"; do
                [ -z "$_p" ] && continue
                abs_path="$(cd "$SCRIPT_DIR" && realpath -m "$_p" 2>/dev/null || echo "$_p")"
                EXTRA_VOLUMES="$EXTRA_VOLUMES -v $abs_path:$abs_path:ro"
                RESOLVED_ARGS+=("$abs_path")
            done
            continue
        fi
        case "$arg" in
            --data-path)
                CONSUMING_DATA_PATHS=true
                RESOLVED_ARGS+=("$arg")
                ;;
            --port)
                EXPECT_PORT=true
                RESOLVED_ARGS+=("$arg")
                ;;
            --master-port)
                EXPECT_MASTER_PORT=true
                RESOLVED_ARGS+=("$arg")
                ;;
            *)
                RESOLVED_ARGS+=("$arg")
                ;;
        esac
    done

    # Export port overrides so compose.yml's ${PRAXIS_PORT}/${PRAXIS_MASTER_PORT}
    # substitution publishes the right host ports. Unset means compose falls
    # back to its own defaults (2100 / 29500).
    [ -n "$PRAXIS_PORT_OVERRIDE" ] && export PRAXIS_PORT="$PRAXIS_PORT_OVERRIDE"
    [ -n "$PRAXIS_MASTER_PORT_OVERRIDE" ] && export PRAXIS_MASTER_PORT="$PRAXIS_MASTER_PORT_OVERRIDE"

    # Pass the host user's ids into the container (compose.yml forwards them as
    # HOST_UID/HOST_GID). The in-container branch below re-execs as that user so
    # files written into the bind-mounted repo are host-owned, not root.
    export HOST_UID="$(id -u)" HOST_GID="$(id -g)"

    docker compose -f "$COMPOSE_FILE" run --rm --remove-orphans --service-ports $EXTRA_VOLUMES agent ./launch "${RESOLVED_ARGS[@]}"
    exit $?
fi

# Check if we're running inside a Docker container
if [ -f /.dockerenv ] || [ -n "${CONTAINER:-}" ]; then
    echo "[DOCKER] Running inside container..."

    # Re-exec as the host user so anything written into the bind-mounted repo is
    # owned by the host user, not root (the recurring permission headache). The
    # host launch passed its ids via HOST_UID/HOST_GID; we chown the named
    # volumes (venv, cache under HOME) to match once, then drop privileges with
    # setpriv (util-linux, in the base image). The re-exec lands here again as a
    # non-root uid and falls straight through.
    if [ "$(id -u)" = "0" ] && [ -n "${HOST_UID:-}" ] && [ "${HOST_UID}" != "0" ]; then
        host_gid="${HOST_GID:-$HOST_UID}"
        export HOME=/home/dev
        mkdir -p "$HOME" "$SCRIPT_DIR/.venv"
        for d in "$HOME" "$SCRIPT_DIR/.venv"; do
            if [ "$(stat -c %u "$d" 2>/dev/null || echo 0)" != "${HOST_UID}" ]; then
                chown -R "${HOST_UID}:${host_gid}" "$d" 2>/dev/null || true
            fi
        done
        # One-time migration: earlier root runs may have left root-owned files in
        # the bind-mounted repo (build/, research/, *.egg-info, __pycache__) that
        # the host user now cannot write. Chown just those non-host-owned files;
        # the sentinel gates the full-tree walk to once per uid (-xdev stays on
        # the bind mount, so it skips the .venv/.cache volumes handled above).
        migr="$SCRIPT_DIR/.host-uid-migrated"
        if [ "$(cat "$migr" 2>/dev/null)" != "${HOST_UID}" ]; then
            echo "[DOCKER] Migrating root-owned files to host user (one-time)..."
            find "$SCRIPT_DIR" -xdev -not -user "${HOST_UID}" \
                -exec chown "${HOST_UID}:${host_gid}" {} + 2>/dev/null || true
            echo "${HOST_UID}" > "$migr" 2>/dev/null || true
        fi
        echo "[DOCKER] Running as host user ${HOST_UID}:${host_gid}"
        exec setpriv --reuid="${HOST_UID}" --regid="${host_gid}" --clear-groups \
            "$SCRIPT_DIR/launch" "$@"
    fi

    # Ensure .venv directory exists and is writable
    mkdir -p "$SCRIPT_DIR/.venv"
fi

# Ensure we have a functional virtual environment and activate it
if [ ! -f "$SCRIPT_DIR/.venv/bin/activate" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$SCRIPT_DIR/.venv"
fi

echo "[SYSTEM] Activated virtual environment."
. "$SCRIPT_DIR/.venv/bin/activate"

# Ray is an optional Praxis extra (see pyproject.toml). Ray publishes no
# wheels for Python >= 3.14 upstream, so we only request the '[ray]'
# extra on interpreters where it can actually install. This single piece
# of logic runs in both environments we care about:
#
#   - the host venv on a bleeding-edge distro (e.g. Arch's python3.14):
#       RAY_SUPPORTED=false  -> installs praxis without ray, and the
#       mono_forward guard below will fail loud if selected.
#   - the Docker compose container (ubuntu:24.04 -> python3.12):
#       RAY_SUPPORTED=true   -> installs praxis with the [ray] extra,
#       so the Ray trainer path is ready to run.
#
# There is no separate Docker install path; both live here.
RAY_SUPPORTED=false
PY_MAJOR_MINOR=$(python -c 'import sys; print(f"{sys.version_info[0]}.{sys.version_info[1]}")' 2>/dev/null || echo "unknown")
case "$PY_MAJOR_MINOR" in
    3.10|3.11|3.12|3.13) RAY_SUPPORTED=true ;;
esac

# Install praxis package if not already installed
if [ -f "$SCRIPT_DIR/pyproject.toml" ]; then
    if ! python -c "import praxis" 2>/dev/null; then
        if $RAY_SUPPORTED; then
            echo "[ENV] Installing Praxis with Ray extra (Python ${PY_MAJOR_MINOR})..."
            # `pip install -e "$DIR[ray]"` is the standard way to install a
            # local editable project with extras. Quoted to keep `[` and `]`
            # out of bash's glob expansion.
            pip install -e "${SCRIPT_DIR}[ray]"
        else
            echo "[ENV] Installing Praxis in development mode (Python ${PY_MAJOR_MINOR} has no Ray wheels; skipping '[ray]' extra)..."
            pip install -e "$SCRIPT_DIR"
        fi
        echo "[ENV] Praxis installation complete"
    elif $RAY_SUPPORTED && ! python -c "import ray" 2>/dev/null; then
        # Existing praxis install on a Ray-capable interpreter, but Ray
        # itself was never added. This is the first-boot path inside the
        # Docker container after the Phase 1 pivot: the container's
        # named `venv` volume pre-dates the [ray] extra, so we catch up
        # lazily the first time launch runs here.
        echo "[ENV] Adding Ray extra to existing Praxis install (Python ${PY_MAJOR_MINOR})..."
        pip install -e "${SCRIPT_DIR}[ray]"
        echo "[ENV] Ray extra installation complete"
    else
        echo "[ENV] Praxis is installed."
    fi
fi

# If first argument is 'test', route remaining args to pytest instead of main.py.
# Works standalone or via `./launch compose test ...` (the compose branch
# re-invokes this script inside the container with the remaining args).
if [ "$1" = "test" ]; then
    shift
    pytest "$@"
    EXIT_CODE=$?
    deactivate
    exit $EXIT_CODE
fi

# Guard: the Mono-Forward trainer's current worker backend is Ray,
# which is an optional extra ('ray') with no wheels on Python >= 3.14.
# Rather than forcing every contributor to install an older Python
# system-wide, Ray-requiring runs live in the Docker compose
# environment (Ubuntu 24.04 + Python 3.12). Detect the Ray-requiring
# trainer here and fail loud with an actionable message instead of
# producing an opaque ImportError mid-training.
NEEDS_RAY=false
for arg in "$@"; do
    if [ "$arg" = "mono_forward_ray" ]; then
        NEEDS_RAY=true
        break
    fi
done
if $NEEDS_RAY && ! python -c "import ray" 2>/dev/null; then
    cat >&2 <<'EOF'
[ERROR] --trainer-type mono_forward_ray requires the optional 'ray' extra,
        which is not installed in this virtual environment.

        Ray publishes no wheels for Python >= 3.14, so the typical path
        is to run inside the Docker compose environment (Ubuntu 24.04 +
        Python 3.12, where Ray installs cleanly):

            ./launch compose --mike --trainer-type mono_forward_ray ...

        To install Ray in this local venv instead (only works on
        Python 3.10-3.13):

            source .venv/bin/activate
            pip install -e '.[ray]'
            deactivate

        For single-host training, use --trainer-type mono_forward
        (the in-process profile, no Ray dependency).
EOF
    exit 1
fi

# Pass all arguments directly to main.py
python "$SCRIPT_DIR/main.py" "$@"
EXIT_CODE=$?

# Deactivate the virtual environment and exit with the command's exit code
deactivate
exit $EXIT_CODE