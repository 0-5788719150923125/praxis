# Godot 4+ specific ignores
.godot/
/android/

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Exported builds
/build/
*.exe
*.pck
*.zip

# Recorded output and source audio (drop your own song.wav in audio/)
/audio/
*.avi
*.mp4
*.png.import.bak

# Auto-generated import metadata - Godot regenerates these on editor open.
*.uid
*.import