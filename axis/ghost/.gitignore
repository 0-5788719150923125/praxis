# Godot 4+ specific ignores
.godot/
/android/

# Transient: the exporter writes override.cfg to set the render's output resolution,
# then removes it when the render finishes (see scripts/exporter.gd).
override.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Exported builds
/build/
*.exe
*.pck
*.zip

# Authoring feedback channel (scene records + screenshots written by the feedback
# console - a working comms channel between author and tooling, not an artifact).
/feedback/

# Recorded output and source audio (drop your own song.wav in audio/)
/audio/
*.avi
*.mp4
*.png.import.bak

# Auto-generated import metadata - Godot regenerates these on editor open.
*.uid
*.import