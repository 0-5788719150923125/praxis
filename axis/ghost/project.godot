; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ghost"
config/description="A spectral music visualizer - scene definitions modulated by audio features."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
config/icon="res://icon.svg"

[audio]

; A fatter driver buffer so heavy scenes (a saturated machine preempting the
; audio callback) cannot crackle the output. Latency is irrelevant here -
; nothing is interactive at audio rate.
driver/output_latency=40

[autoload]

Boot="*res://scripts/boot.gd"
Spectrum="*res://scripts/spectrum.gd"
Director="*res://scripts/director.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

anti_aliasing/quality/msaa_2d=2
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
